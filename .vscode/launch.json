{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run: Refresh + Validate Test Builds",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\refresh-and-validate-test-builds.ps1\""
    },
    {
      "name": "Run: Refresh Test Builds",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\refresh-test-builds.ps1\""
    },
    {
      "name": "Run: Validate Test Builds",
      "type": "node-terminal",
      "request": "launch",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\validate-test-builds.ps1\""
    }
  ]
}
